# Credenciales de la base MariaDB/MySQL para VipManager.
# Estas variables las tiene que tener seteadas el PROCESO del server de CS2
# (en el script que lo arranca, el servicio de systemd, docker-compose, etc).
# No van en VipManager.json.

VIPMANAGER_DB_HOST=127.0.0.1
VIPMANAGER_DB_PORT=3306
VIPMANAGER_DB_NAME=cs2vip
VIPMANAGER_DB_USER=root
VIPMANAGER_DB_PASSWORD=changeme
